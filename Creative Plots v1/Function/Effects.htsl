if (hasPotion "Invisibility", !hasGroup "Moderator" true) {
  stat invis = 0
  clearEffects
}

if or (hasTeam "NoPvP", hasGroup "Banned") {
  applyPotion "Weakness" 1 10 true
}

if (stat nvn == 1) {
  applyPotion "Night Vision" 2592000 1
}

if (stat invis == 1) {
  applyPotion "Invisibility" 2592000 1
}