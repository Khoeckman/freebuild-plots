// @global

// Event input: req, x, y, z
// Event output: res, target, nearest

// @temp x, y, z - Position of the player
// @temp dx, dy, dz, sum, dist

// @compile all
// @todo test if ChatGPT did good

// If player sent the request himself
if (globalvar req == %player.name%) {
  exit
}

var x = %player.pos.x%
var y = %player.pos.y%
var z = %player.pos.z%

// deltaX = x - trustX
if () {
  var dx = var x
  var dx -= globalvar trustX

  // dx^2
  var temp = var dx
  var temp *= var dx
  var sum = var temp

  // deltaY = y - trustY
  var dy = var y
  var dy -= globalvar trustY

  // dy^2
  var temp = var dy
  var temp *= var dy
  var sum += var temp

  // deltaZ = z - trustZ
  var dz = var z
  var dz -= globalvar trustZ

  // dz^2
  var temp = var dz
  var temp *= var dz
  var sum += var temp

  // Initial guess for sqrt
  var dist = var sum
  var dist /= 2.0
}

// Newton-Raphson Iteration 1
var temp = var sum
var temp /= var dist
var dist += var temp
var dist /= 2.0

// Iteration 2 (optional)
var temp = var sum
var temp /= var dist
var dist += var temp
var dist /= 2.0

if (var dist < globalvar trustNearest) {
  globalvar res = %player.name%
  // globalvar target = globalvar req
  globalvar trustNearest = var dist
  // function "Response nearest player" true
}