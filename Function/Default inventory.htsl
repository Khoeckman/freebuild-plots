if (hasGroup "Owner") {
  giveItem "PlotsMenu" true 7 true
  giveItem "HousingMenu" true 8 true
  exit
}

if (hasGroup "Staff" true) {
  giveItem "PlotsMenu" true 7 true
  giveItem "HousingAdminMenu" true 8 true
} else {
  giveItem "PlotsMenu" true 8 true
}